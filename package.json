{
  "name": "@ajabadia/styles",
  "version": "1.0.55",
  "type": "module",
  "description": "Industrial multi-tenant dynamic styling engine and common visual assets for ABD suite.",
  "main": "dist/index.js",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajabadia/ABDStyles.git"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cpy \"src/styles/**/*\" dist/styles",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "audit": "powershell ./scripts/abd-audit.ps1"
  },
  "keywords": [
    "abd",
    "theme",
    "multi-tenant",
    "branding",
    "tailwind",
    "yiq"
  ],
  "author": "ABD Team",
  "license": "UNLICENSED",
  "dependencies": {
    "clsx": "2.1.1",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "lucide-react": "^0.46.0 || ^1.0.0",
    "next-intl": "^4.12.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "cpy-cli": "^5.0.0",
    "lucide-react": "catalog:",
    "next-intl": "catalog:",
    "react": "catalog:",
    "tsup": "^8.3.5",
    "typescript": "catalog:",
    "vite": "^6.0.0",
    "vitest": "catalog:"
  }
}
